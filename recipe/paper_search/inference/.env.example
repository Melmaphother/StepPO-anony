# Copy to `.env` locally and fill in machine-specific values.

# --- vLLM policy ---
PAPER_SEARCH_INFERENCE_MODEL_PATH=Qwen/Qwen3-4B-Instruct-2507
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=10240
PAPER_SEARCH_INFERENCE_MAX_NEW_TOKENS=4096
PAPER_SEARCH_INFERENCE_TEMPERATURE=0.0
PAPER_SEARCH_TOOL_PARSER=hermes

# Optional tokenizer.apply_chat_template kwargs, e.g. {"enable_thinking": false}
# PAPER_SEARCH_APPLY_CHAT_TEMPLATE_KWARGS=

# --- Paper retrieval ---
PAPER_SEARCH_BASE_URL=http://localhost:4000
PAPER_AGENT_V2_SEARCH_SOURCE=serper
# PAPER_SEARCH_SERPER_API_KEYS=
# SERPER_API_KEY=
# SERPER_SEARCH_URL=
PAPER_AGENT_V2_PAPER_FROM=
PAPER_AGENT_V2_PAPER_TO=

# --- Selector HTTP API ---
PAPERSEARCH_SELECTOR_BASE_URL=http://localhost:8000
PAPERSEARCH_SELECTOR_MODEL_NAME=selector-qwen-8b

# --- Batch IO ---
PAPER_AGENT_V2_DATASET=recipe/paper_search/inference/datasets/test_case.jsonl
PAPER_AGENT_V2_SAVE_DIR=outputs/paper_search
PAPER_AGENT_V2_RETRY_ROUNDS=1
PAPER_SEARCH_INFERENCE_MAX_STEPS=5
